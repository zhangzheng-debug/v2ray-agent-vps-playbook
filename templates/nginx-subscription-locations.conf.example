# Include inside the TLS server block for <EDGE_DOMAIN>.
# Replace every placeholder. Confirm whether the upstream speaks http or https.
# These are exact-match locations: do not replace "=" with a broad prefix match.

location = /s/clashMetaProfiles/<PROFILE_TOKEN> {
    proxy_pass https://127.0.0.1:<SUBSCRIPTION_PORT>/s/clashMetaProfiles/<PROFILE_TOKEN>;
    proxy_http_version 1.1;
    proxy_set_header Host <EDGE_DOMAIN>;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_ssl_server_name on;
    proxy_ssl_name <EDGE_DOMAIN>;
    proxy_ssl_protocols TLSv1.2 TLSv1.3;
    proxy_connect_timeout 5s;
    proxy_read_timeout 30s;
    add_header Cache-Control "private, no-store" always;
}

location = /s/clashMeta/<PROFILE_TOKEN> {
    proxy_pass https://127.0.0.1:<SUBSCRIPTION_PORT>/s/clashMeta/<PROFILE_TOKEN>;
    proxy_http_version 1.1;
    proxy_set_header Host <EDGE_DOMAIN>;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_ssl_server_name on;
    proxy_ssl_name <EDGE_DOMAIN>;
    proxy_ssl_protocols TLSv1.2 TLSv1.3;
    proxy_connect_timeout 5s;
    proxy_read_timeout 30s;
    add_header Cache-Control "private, no-store" always;
}

# VLESS WebSocket example. The local Xray listener should bind to loopback only.
location = /ws/<RANDOM_WS_PATH> {
    proxy_pass http://127.0.0.1:<LOCAL_XRAY_WS_PORT>;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_read_timeout 300s;
}
