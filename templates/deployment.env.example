# Copy this file OUTSIDE the Git repository and replace placeholders locally.
# Never commit deployment.env.

SERVER_HOST=203.0.113.10
SERVER_USER=root
SSH_KEY_PATH=C:/Users/USER/.ssh/id_ed25519

# Use separate names when possible.
REALITY_HOST=direct.example.com
EDGE_HOST=edge.example.com

# Cloudflare is enabled only for EDGE_HOST.
CF_PROXY_EDGE=true
CF_PROXY_REALITY=false
CF_SSL_MODE=full_strict

# Generate at deployment time and store outside Git.
PROFILE_TOKEN=REPLACE_WITH_RANDOM_32_PLUS_CHARACTERS
REALITY_PORT=24443

# Recommended defaults.
ENABLE_IPV6=false
INSTALL_REALITY=true
INSTALL_VLESS_WS=true
INSTALL_VMESS_WS=false

# Set only in the local untracked file or secret manager.
CF_API_TOKEN=
